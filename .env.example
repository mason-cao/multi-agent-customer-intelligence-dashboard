# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Database
DATABASE_URL=sqlite:///data/nexus.db

# Owner access, optional
# Leave unset to create an owner passcode from the Workspaces screen.
# Set this only when you want a deployment-level owner secret.
ADMIN_API_TOKEN=

# ChromaDB
CHROMA_PERSIST_DIR=data/chroma

# App
APP_ENV=development
LOG_LEVEL=INFO
